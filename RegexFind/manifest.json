{
  "manifest_version": 3,
  "name": "Regex Find",
  "description": "Regex find-on-page for Safari",
  "version": "1.0.0",
  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/toolbar-icon-16.png",
      "32": "images/toolbar-icon-32.png"
    },
    "default_title": "Regex Find"
  },
  "permissions": ["activeTab"],
  "content_scripts": [{
    "js": ["content.js"],
    "css": ["content.css"],
    "matches": ["<all_urls>"],
    "run_at": "document_idle"
  }],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Open Regex Find"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module",
    "persistent": false
  }
}
